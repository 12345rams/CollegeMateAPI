# ===== Backend Environment Variables =====
# Copy this file to a .env file or set these as system environment variables

# Server
SERVER_PORT=8080

# MongoDB
MONGODB_URI=

# JWT
JWT_SECRET=
JWT_EXPIRATION_MS=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# Qdrant Vector Database
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=collegemate
